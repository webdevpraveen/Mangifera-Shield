# Dasheri Shield - Environment Variables
# Copy this to .env and fill in your keys

# OpenWeatherMap API (free tier: https://openweathermap.org/api)
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# data.gov.in API (optional, fallback data included)
DATA_GOV_API_KEY=your_data_gov_api_key_here

# Bhashini API (optional, Web Speech API used as primary)
BHASHINI_USER_ID=
BHASHINI_ULCA_API_KEY=
BHASHINI_INFERENCE_API_KEY=

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true
